font-family = MonoLisa Variable

font-variation = wght=400
font-variation-italic = wght=400
font-variation-bold = wght=900
font-variation-bold-italic = wght=900

adjust-cell-width = -5%
adjust-cell-height = 20%
adjust-cursor-height = 20%

# cursive 'f'
font-feature = ss02
# plex-like braces
font-feature = ss07
# nicer hex '0x'
font-feature = ss11
# nicer '&'
font-feature = ss14
# no base on 'i'
# font-feature = ss15
# no base on 'r'#
font-feature = ss16

# vim: ft=config
